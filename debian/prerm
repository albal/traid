#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /run/systemd/system ]; then
            systemctl stop traid-web.service    || true
            systemctl stop traid-worker.service || true
        fi

        # Disable lighttpd site on remove; leave in place for upgrade
        # (postinst will re-enable it).
        if [ "$1" = "remove" ] && command -v lighty-disable-mod >/dev/null 2>&1; then
            lighty-disable-mod traid || true
            if [ -d /run/systemd/system ]; then
                systemctl reload-or-restart lighttpd.service || true
            fi
        fi
        ;;
    failed-upgrade)
        ;;
esac

#DEBHELPER#
exit 0
