# TRAID: block qemu-system-gui (GTK/SDL display libraries)
# qemu-system-x86 Recommends qemu-system-gui, which pulls in GTK and SDL.
# TRAID is a headless appliance managed via a browser UI — no physical display
# is ever needed.  Block the GUI package so apt does not install it.
Package: qemu-system-gui
Pin: release *
Pin-Priority: -1
