#!/usr/bin/make -f

INSTALL_DIR = /usr/lib/traid
PKG_DIR     = $(CURDIR)/debian/traid

%:
	dh $@

override_dh_auto_build:
	# Build the traid wheel from source into vendor/.
	python3.13 -m pip wheel --no-deps . -w vendor/
	# Pre-download all runtime dependency wheels (with transitive deps) into vendor/.
	# Must use python3.13 explicitly so compiled wheels (e.g. pydantic-core)
	# are fetched for the correct ABI that the target system will use.
	python3.13 -m pip download \
	    fastapi==0.111.0 \
	    "uvicorn[standard]==0.29.0" \
	    pydantic==2.7.1 \
	    python-json-logger==2.0.7 \
	    -d vendor/ --quiet

override_dh_auto_install:
	install -d $(PKG_DIR)$(INSTALL_DIR)/vendor
	cp vendor/*.whl $(PKG_DIR)$(INSTALL_DIR)/vendor/
	cp -r static $(PKG_DIR)$(INSTALL_DIR)/

	# Install systemd units, rewriting dev paths to installed paths.
	install -d $(PKG_DIR)/usr/lib/systemd/system
	sed \
	    -e 's|/home/al/TRAID/venv|$(INSTALL_DIR)/venv|g' \
	    -e 's|WorkingDirectory=.*|WorkingDirectory=$(INSTALL_DIR)|g' \
	    systemd/hybrid-worker.service \
	    > $(PKG_DIR)/usr/lib/systemd/system/hybrid-worker.service
	sed \
	    -e 's|/home/al/TRAID/venv|$(INSTALL_DIR)/venv|g' \
	    -e 's|WorkingDirectory=.*|WorkingDirectory=$(INSTALL_DIR)|g' \
	    systemd/hybrid-web.service \
	    > $(PKG_DIR)/usr/lib/systemd/system/hybrid-web.service

override_dh_auto_test:
	# Tests require a running worker daemon — skip during package build.

override_dh_installsystemd:
	# Service lifecycle is managed in postinst/prerm.
