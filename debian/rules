#!/usr/bin/make -f

INSTALL_DIR = /usr/lib/traid
PKG_DIR     = $(CURDIR)/debian/traid

%:
	dh $@

override_dh_auto_build:
	# Build the traid application wheel (pure Python, no compilation needed).
	python3.13 -m pip wheel --no-deps . -w vendor/
	# Download all runtime dependency wheels for Python 3.13/amd64.
	# --only-binary :all: ensures only pre-built wheels are fetched — no source
	# tarballs that would be silently excluded from the package by cp *.whl.
	python3.13 -m pip download \
	    --only-binary :all: \
	    "fastapi==0.135.3" \
	    "uvicorn[standard]==0.44.0" \
	    "pydantic==2.13.0" \
	    "python-json-logger==4.1.0" \
	    -d vendor/

override_dh_auto_install:
	install -d $(PKG_DIR)$(INSTALL_DIR)/vendor
	cp vendor/*.whl $(PKG_DIR)$(INSTALL_DIR)/vendor/

	# Static files served by lighttpd from /usr/share/traid.
	install -d $(PKG_DIR)/usr/share/traid
	cp -r static/. $(PKG_DIR)/usr/share/traid/

	# lighttpd site configuration.
	install -d $(PKG_DIR)/etc/lighttpd/conf-available
	install -m 0644 lighttpd/traid.conf $(PKG_DIR)/etc/lighttpd/conf-available/traid.conf

	# Install systemd units (already reference /usr/lib/traid directly).
	install -d $(PKG_DIR)/usr/lib/systemd/system
	cp systemd/traid-worker.service $(PKG_DIR)/usr/lib/systemd/system/
	cp systemd/traid-web.service    $(PKG_DIR)/usr/lib/systemd/system/

override_dh_auto_test:
	# Tests require a running worker daemon — skip during package build.

override_dh_installsystemd:
	# Service lifecycle is managed in postinst/prerm.
